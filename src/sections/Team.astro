---
import { type Lang, useTranslations } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

// TODO Jaime: define what goes here. Options to discuss:
//   - grid of members with photo + role
//   - editorial paragraph about the studio's people
//   - just names + social links
// Until decided, this section renders a placeholder.
const members: Array<{ name: string; role: string; photo?: string }> = [];
---

<section id="team" class="relative bg-n28-black text-n28-white">
  <div class="mx-auto max-w-7xl px-6 py-24 md:px-10 md:py-32">
    <h2 class="font-display text-[20vw] uppercase leading-[0.85] md:text-[12rem]">
      {t('team.title')}
    </h2>

    {members.length === 0 ? (
      <p class="mt-12 max-w-2xl text-base text-n28-white/60 md:text-lg">
        {t('team.placeholder')}
      </p>
    ) : (
      <ul class="mt-16 grid grid-cols-2 gap-8 md:grid-cols-4">
        {members.map((m) => (
          <li class="flex flex-col gap-3">
            {m.photo && (
              <img
                src={m.photo}
                alt={m.name}
                class="aspect-[3/4] w-full object-cover grayscale"
              />
            )}
            <div>
              <p class="font-display text-2xl uppercase">{m.name}</p>
              <p class="text-xs uppercase tracking-widest text-n28-white/60">{m.role}</p>
            </div>
          </li>
        ))}
      </ul>
    )}
  </div>
</section>

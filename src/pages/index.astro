    <p class="mb-4 text-sm uppercase tracking-widest text-neutral-400">
      Work in progress
    </p>
    <h1 class="text-balance text-5xl font-semibold tracking-tight sm:text-6xl">
      Landing de videobooks
    </h1>
    <p class="mt-6 max-w-xl text-balance text-neutral-300">
      Scaffolding de Astro + Tailwind v4 listo. Las secciones reales se montan en la siguiente fase.
    </p>
  </main>
</Layout>

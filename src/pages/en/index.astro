  <Marquee text="N28PROJECT" class="bg-n28-red text-n28-white" />
  <Work lang="en" />
  <PaperTear color="var(--color-n28-black)" edge="top" height={80} />
  <Team lang="en" />
  <Contact lang="en" />
</Layout>
